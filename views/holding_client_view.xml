<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="myndo.holding_client_form" model="ir.ui.view">
    <field name="name">myndo.holding_client_form</field>		
    <field eval="10" name="priority"/>
    <field name="model">myndo.holding_client</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <field name="name"/>
          <field name="agency_id"/>
          <field name="client_ids" context="{'default_holding_client_id' : id}"/>
        </group>
	    </form>
    </field>
  </record>

  <record id="myndo.holding_client_tree" model="ir.ui.view">
    <field name="name">myndo.holding_client_tree</field>
    <field eval="10" name="priority"/>
    <field name="model">myndo.holding_client</field>		
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="agency_id"/>
        <field name="client_ids" widget="many2many_tags" context="{'default_holding_client_id' : id}"/>
      </list>
    </field>
  </record>
  
	<record id="myndo.holding_client_search" model="ir.ui.view">
    <field name="name">myndo.holding_client_search</field>
		<field eval="10" name="priority"/>
    <field name="model">myndo.holding_client</field>		
		<field name="arch" type="xml">
      <search string="Holding client Search">
        <field name="name" />
        <field name="client_ids"/>
      </search>
    </field>
  </record>

  <!-- holding client -->
  <record id="myndo.holding_client_action" model="ir.actions.act_window"><field name="name">Holding client</field>
		<field name="res_model">myndo.holding_client</field>	
		<field name="view_mode">list,kanban,form</field>		
		<field name="search_view_id" ref="myndo.holding_client_search"/>
		<field name="view_id" ref="myndo.holding_client_tree"/>
		<field name="help" type="html">
		  <p class="oe_view_nocontent_create">Click to add a holding client.</p>
		</field>
	</record>

</odoo>