<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_myndo_area_test_form" model="ir.ui.view">
    <field name="name">myndo.area_test_form</field>
    <field name="model">myndo.area_test</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="area_id"/>
                    <field name="description"/>
                </group>
                <notebook>
                    <page string="JSON Preview">
                        <button name="action_generate_preview" string="Generate JSON Structure" type="object" class="oe_highlight"/>
                        <field name="generated_json" widget="ace" options="{'mode': 'json'}"/>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
  </record>

	<record id="myndo.area_test_tree" model="ir.ui.view">
    <field name="name">myndo.area_test_tree</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.area_test</field>
    <field name="arch" type="xml">
      <list>
        <field name="name" />
        <field name="description" />
      </list>
    </field>
  </record>

  <record id="myndo.area_test_search" model="ir.ui.view">
    <field name="name">myndo.area_test_search</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.area_test</field>
    <field name="arch" type="xml">
      <search string="Area Test">
        <field name="name" />
      </search>
    </field>
  </record>


  <record id="myndo.myndo_area_test_action" model="ir.actions.act_window">
    <field name="name">Area Test</field>
		<field name="res_model">myndo.area_test</field>	
		<field name="view_mode">list,kanban,form</field>		
		<field name="search_view_id" ref="myndo.area_test_search"/>
		<field name="view_id" ref="myndo.area_test_tree"/>
		<field name="help" type="html">
		  <p class="oe_view_nocontent_create">Click to add an area test.</p>
		</field>
	</record>

</odoo>