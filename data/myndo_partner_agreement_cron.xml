<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        Daily cron to refresh stored state on myndo.partner_agreement.
        Stored compute fields don't re-evaluate when "today" changes,
        so we trigger recomputation every night for non-expired records.
    -->
    <record id="ir_cron_refresh_agreement_state" model="ir.cron">
        <field name="name">Myndo: Refresh Agreement State</field>
        <field name="model_id" ref="model_myndo_partner_agreement"/>
        <field name="state">code</field>
        <field name="code">model._cron_refresh_agreement_state()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
