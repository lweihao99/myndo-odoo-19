<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Client Partnership Archive - Form                              -->
    <!-- ============================================================ -->
    <record id="myndo.partner_client_form" model="ir.ui.view">
        <field name="name">myndo.partner_client_form</field>
        <field eval="10" name="priority"/>
        <field name="model">myndo.partner_client</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="active,inactive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Archive name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="client_id" options="{'no_create': True}"/>
                            <field name="industry_id"/>
                            <field name="default_rebate"/>
                        </group>
                        <group>
                            <field name="dashboard_user_id"/>
                            <field name="main_contact_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="tag_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Billing -->
                        <page string="Billing" name="billing">
                            <group>
                                <group>
                                    <field name="company_name"/>
                                    <field name="vat_id"/>
                                    <field name="fiscal_code"/>
                                    <field name="pec_sdi"/>
                                    <field name="payment_terms"/>
                                </group>
                                <group>
                                    <field name="address"/>
                                    <field name="postal_code"/>
                                    <field name="city"/>
                                    <field name="country_id"/>
                                </group>
                            </group>
                        </page>

                        <!-- Contacts -->
                        <page string="Contacts" name="contacts">
                            <field name="contact_ids"
                                   context="{'default_client_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="surname"/>
                                    <field name="role"/>
                                    <field name="email"/>
                                    <field name="phone"/>
                                    <field name="fiscal_code"/>
                                    <field name="is_main" readonly="1"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="name"/>
                                                <field name="surname"/>
                                                <field name="role"/>
                                                <field name="fiscal_code"/>
                                            </group>
                                            <group>
                                                <field name="email"/>
                                                <field name="phone"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <!-- Rebates -->
                        <page string="Rebates" name="rebates">
                            <field name="rebate_ids">
                                <list editable="bottom">
                                    <field name="media_type_id"/>
                                    <field name="rebate_percent"/>
                                </list>
                            </field>
                        </page>

                        <!-- Platform Accounts -->
                        <page string="Platform Accounts" name="accounts">
                            <field name="account_ids">
                                <list editable="bottom">
                                    <field name="platform_id"/>
                                    <field name="external_account_id"/>
                                    <field name="external_account_name"/>
                                </list>
                            </field>
                        </page>

                        <!-- Saleshouse Periods -->
                        <page string="Saleshouse Periods" name="saleshouse">
                            <field name="saleshouse_period_ids">
                                <list editable="bottom">
                                    <field name="saleshouse_name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                </list>
                            </field>
                        </page>

                        <!-- Brands (read-only from client hierarchy) -->
                        <page string="Brands &amp; Divisions" name="brands">
                            <group>
                                <field name="division_ids" readonly="1" widget="many2many_tags"/>
                                <field name="brand_ids" readonly="1" widget="many2many_tags"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Client Partnership Archive - List                              -->
    <!-- ============================================================ -->
    <record id="myndo.partner_client_tree" model="ir.ui.view">
        <field name="name">myndo.partner_client_tree</field>
        <field eval="10" name="priority"/>
        <field name="model">myndo.partner_client</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="client_id"/>
                <field name="industry_id"/>
                <field name="default_rebate"/>
                <field name="dashboard_user_id"/>
                <field name="status"
                       decoration-success="status == 'active'"
                       decoration-muted="status == 'inactive'"/>
                <field name="tag_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}"/>
            </list>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Client Partnership Archive - Kanban                            -->
    <!-- ============================================================ -->
    <record id="myndo.partner_client_kanban" model="ir.ui.view">
        <field name="name">myndo.partner_client_kanban</field>
        <field eval="10" name="priority"/>
        <field name="model">myndo.partner_client</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name"/>
                <field name="client_id"/>
                <field name="default_rebate"/>
                <field name="tag_ids"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="client_id"/><br/>
                                <span>Default rebate: <field name="default_rebate"/>%</span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <field name="tag_ids" widget="many2many_tags"
                                       options="{'color_field': 'color'}"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Client Partnership Archive - Search                            -->
    <!-- ============================================================ -->
    <record id="myndo.partner_client_search" model="ir.ui.view">
        <field name="name">myndo.partner_client_search</field>
        <field eval="10" name="priority"/>
        <field name="model">myndo.partner_client</field>
        <field name="arch" type="xml">
            <search string="Client Archives">
                <field name="name"/>
                <field name="client_id"/>
                <field name="industry_id"/>
                <field name="dashboard_user_id"/>
                <field name="tag_ids"/>
                <filter name="active" string="Active"
                        domain="[('status','=','active')]"/>
                <filter name="inactive" string="Inactive"
                        domain="[('status','=','inactive')]"/>
                <separator/>
                <filter name="my_archives" string="My Archives"
                        domain="[('dashboard_user_id','=',uid)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_industry" string="Industry"
                            context="{'group_by': 'industry_id'}"/>
                    <filter name="group_owner" string="Owner"
                            context="{'group_by': 'dashboard_user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Action                                                         -->
    <!-- ============================================================ -->
    <record id="myndo.partner_client_action" model="ir.actions.act_window">
        <field name="name">Client Archives</field>
        <field name="res_model">myndo.partner_client</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="myndo.partner_client_search"/>
        <field name="view_id" ref="myndo.partner_client_tree"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new Client Partnership Archive.
            </p>
        </field>
    </record>

</odoo>
