<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="myndo.unicode_list_form" model="ir.ui.view">
    <field name="name">myndo.unicode_list_form</field>		
    <field eval="10" name="priority"/>
    <field name="model">myndo.unicode_list</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <field name="template_id"/>
          <field name="rel_rule_id"/>
          <field name="unicode"/>
          <field name="naming_convention"/>
        </group>
	    </form>
    </field>
  </record>

  <record id="myndo.unicode_list_tree" model="ir.ui.view">
    <field name="name">myndo.unicode_list_tree</field>
    <field eval="10" name="priority"/>
    <field name="model">myndo.unicode_list</field>		
    <field name="arch" type="xml">
      <list>
        <field name="template_id"/>
        <field name="rel_rule_id"/>
        <field name="unicode"/>
        <field name="naming_convention"/>
      </list>
    </field>
  </record>
	<record id="myndo.unicode_list_search" model="ir.ui.view">
    <field name="name">myndo.unicode_list_search</field>
		<field eval="10" name="priority"/>
    <field name="model">myndo.unicode_list</field>		
		<field name="arch" type="xml">
      <search string="Unicode list Search">
        <field name="template_id" />
        <field name="rel_rule_id"/>
      </search>
    </field>
  </record>

    <!-- validator items -->
  <record id="myndo.unicode_list_action" model="ir.actions.act_window"><field name="name">Unicode list</field>
		<field name="res_model">myndo.unicode_list</field>	
		<field name="view_mode">list,kanban,form</field>		
		<field name="search_view_id" ref="myndo.unicode_list_search"/>
		<field name="view_id" ref="myndo.unicode_list_tree"/>
		<field name="help" type="html">
		  <p class="oe_view_nocontent_create">Click to add a unicode list.</p>
		</field>
	</record>

</odoo>