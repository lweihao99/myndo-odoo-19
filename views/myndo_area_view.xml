<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="myndo.area_form" model="ir.ui.view">
    <field name="name">myndo.area_form</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.area</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <field name="name" />
          <field name="clean_name" />
          <field name="description" />
          <field name="rel_tag_colors" widget="many2many_tags" options="{'color_field': 'color'}" />
        </group>

        <notebook>
          <page string="Related Columns">
            <group>
              <field name="required_columns" widget="many2many_tags" context="{'default_area_id' : id}" />
            </group>
          </page>
          <page string="Related Subareas">
            <group>
              <field name="rel_subareas" widget="many2many_tags" context="{'default_area_id' : id}" />
            </group>
          </page>
        </notebook>
      </form>
    </field>
  </record>

  <record id="myndo.area_tree" model="ir.ui.view">
    <field name="name">myndo.area_tree</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.area</field>
    <field name="arch" type="xml">
      <list>
        <field name="name" />
        <field name="clean_name" />
        <field name="rel_tag_colors" widget="many2many_tags" options="{'color_field': 'color'}"/>
        <field name="required_columns" widget="many2many_tags" context="{'default_area_id' : id}" />
      </list>
    </field>
  </record>
  <record id="myndo.area_search" model="ir.ui.view">
    <field name="name">myndo.area_search</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.area</field>
    <field name="arch" type="xml">
      <search string="Columns">
        <field name="name" />
        <field name="clean_name" />
        <field name="required_columns" widget="many2many_tags" context="{'default_area_id' : id}" />
      </search>
    </field>
  </record>

  <!-- columns -->
  <record id="myndo.myndo_area_action" model="ir.actions.act_window">
    <field name="name">Area</field>
		<field name="res_model">myndo.area</field>	
		<field name="view_mode">list,kanban,form</field>		
		<field name="search_view_id" ref="myndo.area_search"/>
		<field name="view_id" ref="myndo.area_tree"/>
		<field name="help" type="html">
		  <p class="oe_view_nocontent_create">Click to add a Area.</p>
		</field>
	</record>

</odoo>