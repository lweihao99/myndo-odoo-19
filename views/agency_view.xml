<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="myndo.agency_form" model="ir.ui.view">
    <field name="name">myndo.agency_form</field>		
    <field eval="10" name="priority"/>
    <field name="model">myndo.agency</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <field name="name"/>
          <field name="holding_agency_id"/>
          <field name="holding_client_ids" context="{'default_agency_id' : id}"/>
        </group>
	    </form>
    </field>
  </record>

  <record id="myndo.agency_tree" model="ir.ui.view">
    <field name="name">myndo.agency_tree</field>
    <field eval="10" name="priority"/>
    <field name="model">myndo.agency</field>		
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="holding_agency_id"/>
        <field name="holding_client_ids" widget="many2many_tags" context="{'default_agency_id' : id}"/>
      </list>
    </field>
  </record>
	<record id="myndo.agency_search" model="ir.ui.view">
    <field name="name">myndo.agency_search</field>
		<field eval="10" name="priority"/>
    <field name="model">myndo.agency</field>		
		<field name="arch" type="xml">
      <search string="Agency Search">
        <field name="name" />
        <field name="holding_client_ids"/>
      </search>
    </field>
  </record>

    <!-- agency -->
  <record id="myndo.agency_action" model="ir.actions.act_window"><field name="name">Agency</field>
		<field name="res_model">myndo.agency</field>	
		<field name="view_mode">list,kanban,form</field>		
		<field name="search_view_id" ref="myndo.agency_search"/>
		<field name="view_id" ref="myndo.agency_tree"/>
		<field name="help" type="html">
		  <p class="oe_view_nocontent_create">Click to add a agency.</p>
		</field>
	</record>

</odoo>