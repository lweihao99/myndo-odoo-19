<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="myndo.divisions_form" model="ir.ui.view">
    <field name="name">myndo.divisions_form</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.divisions</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <field name="name" />
          <field name="short_name" />
          <field name="client_id"/>
          <field name="brands" widget="many2many_tags" context="{'default_division_id' : id}" />
        </group>
      </form>
    </field>
  </record>

  <record id="myndo.divisions_tree" model="ir.ui.view">
    <field name="name">myndo.divisions_tree</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.divisions</field>
    <field name="arch" type="xml">
      <list>
        <field name="name" />
        <field name="short_name" />
        <field name="client_id" />
        <field name="brands" widget="many2many_tags" context="{'default_division_id' : id}" />
      </list>
    </field>
  </record>
  <record id="myndo.divisions_search" model="ir.ui.view">
    <field name="name">myndo.divisions_search</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.divisions</field>
    <field name="arch" type="xml">
      <search string="Divisions">
        <field name="name" />
        <field name="client_id" />
        <field name="brands" />
      </search>
    </field>
  </record>

  <!-- divisions -->
  <record id="myndo.divisions_action" model="ir.actions.act_window">
    <field name="name">Divisions</field>
		<field name="res_model">myndo.divisions</field>	
		<field name="view_mode">list,kanban,form</field>		
		<field name="search_view_id" ref="myndo.divisions_search"/>
		<field name="view_id" ref="myndo.divisions_tree"/>
		<field name="help" type="html">
		  <p class="oe_view_nocontent_create">Click to add a divisions.</p>
		</field>
	</record>

</odoo>