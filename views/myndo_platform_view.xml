<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="myndo.platform_form" model="ir.ui.view">
    <field name="name">myndo.platform_form</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.platform</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <field name="name" />
        </group>
      </form>
    </field>
  </record>

  <record id="myndo.platform_tree" model="ir.ui.view">
    <field name="name">myndo.platform_tree</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.platform</field>
    <field name="arch" type="xml">
      <list>
        <field name="name" />
      </list>
    </field>
  </record>
  <record id="myndo.platform_search" model="ir.ui.view">
    <field name="name">myndo.platform_search</field>
    <field eval="10" name="priority" />
    <field name="model">myndo.platform</field>
    <field name="arch" type="xml">
      <search string="Columns">
        <field name="name" />
      </search>
    </field>
  </record>

  <!-- columns -->
  <record id="myndo.myndo_platform_action" model="ir.actions.act_window">
    <field name="name">Platforms</field>
    <field name="res_model">myndo.platform</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="search_view_id" ref="myndo.platform_search" />
    <field name="view_id" ref="myndo.platform_tree" />
    <field name="help" type="html">
      <p class="oe_view_nocontent_create">Click to add a platforms.</p>
    </field>
  </record>

</odoo>