<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="myndo.client_form" model="ir.ui.view">
    <field name="name">myndo.client_form</field>		
    <field eval="10" name="priority"/>
    <field name="model">myndo.client</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <field name="name"/>
          <field name="holding_client_id"/>
          <field name="industry"/>
          <field name="country"/>
          <field name="short_name"/>
          <field name="vat_number"/>
          <field name="client_subarea"/>
        </group>
        <notebook>
          <page string="Divisions">
            <group>
              <field name="divisions_ids" widget="many2many_tags" context="{'default_client_id' : id}" />
            </group>
          </page>
          <page string="Dashboards">
            <group>
              <field name="user_ids">
                <list string="Users" >
                  <field name="name" />
                  <field name="surname" />
                  <field name="role" />
                </list>
              </field>
            </group>
          </page>
        </notebook>
	    </form>
    </field>
  </record>

  <record id="myndo.client_tree" model="ir.ui.view">
    <field name="name">myndo.client_tree</field>
    <field eval="10" name="priority"/>
    <field name="model">myndo.client</field>		
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="holding_client_id"/>
        <field name="divisions_ids" widget="many2many_tags" context="{'default_client_id' : id}" />
      </list>
    </field>
  </record>
	<record id="myndo.client_search" model="ir.ui.view">
    <field name="name">myndo.client_search</field>
		<field eval="10" name="priority"/>
    <field name="model">myndo.client</field>		
		<field name="arch" type="xml">
      <search string="Client Search">
        <field name="name" />
      </search>
    </field>
  </record>

  <!-- client -->
  <record id="myndo.client_action" model="ir.actions.act_window"><field name="name">client</field>
		<field name="res_model">myndo.client</field>	
		<field name="view_mode">list,kanban,form</field>		
		<field name="search_view_id" ref="myndo.client_search"/>
		<field name="view_id" ref="myndo.client_tree"/>
		<field name="help" type="html">
		  <p class="oe_view_nocontent_create">Click to add a client.</p>
		</field>
	</record>

</odoo>